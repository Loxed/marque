  @end card

  @card
    ## Pattern: feature matrix
    Pair stats and cards for density without clutter.
  @end card

  @card .dark
    ## Pattern: deep-dive rail
    Use callouts and steps to guide longer walkthroughs.
  @end card
@end row patterns

